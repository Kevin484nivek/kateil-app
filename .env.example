# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost
APP_TIMEZONE=Europe/Madrid
APP_DOMAIN=kateil.localhost
PUBLIC_APP_NAME=Kateil Platform

# Auth
AUTH_SECRET=change-me
ADMIN_NAME=Administrador Kateil
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Database
POSTGRES_DB=stock_sales
POSTGRES_USER=stock_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://stock_user:change-me@db:5432/stock_sales?schema=public

# Backup
BACKUP_RETENTION_DAYS=14
BACKUP_KEEP_LATEST=14
BACKUP_DIR=/backups
BACKUP_FORMAT=custom
BACKUP_COMPRESSION_LEVEL=9
BACKUP_REMOTE_PROVIDER=none
INTERNAL_AUTOMATION_TOKEN=change-me

# Google Drive OAuth (future app-managed connection)
GOOGLE_DRIVE_OAUTH_CLIENT_ID=change-me
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=change-me
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=https://kateil.localhost/api/storage/google-drive/callback

# Assistant AI (provider-agnostic: openai | groq | anthropic | none)
ASSISTANT_AI_PROVIDER=none
ASSISTANT_AI_MODEL=gpt-4o-mini
ASSISTANT_AI_API_KEY=
ASSISTANT_AI_BASE_URL=
ASSISTANT_AI_TEMPERATURE=0.2
ASSISTANT_AI_MAX_OUTPUT_TOKENS=700
ASSISTANT_AI_TIMEOUT_MS=15000

# GitHub
GITHUB_REPOSITORY=Kevin484nivek/kateil-app
GITHUB_DEFAULT_BRANCH=main
